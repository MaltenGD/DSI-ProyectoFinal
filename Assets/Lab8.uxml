        <ui:VisualElement name="Separator" class="separator"/>
        <ui:VisualElement name="Contenido" class="content-area">
            <ui:VisualElement name="Azul-content" class="content-panel" style="flex-direction: row;">
                <ui:VisualElement style="flex-grow: 1; background-color: rgba(201, 0, 0, 0.71);">
