                            <ui:VisualElement name="ItemIco" style="flex-grow: 1; width: 10%; height: 30%; min-width: 20%; min-height: 80%; background-color: rgba(0, 0, 0, 0.67); flex-direction: row; max-width: 20%; max-height: 80%; margin-right: 5%;"/>
                            <ui:Label text="Label" style="min-width: 30%;"/>
