                    <ui:VisualElement name="Item" style="flex-grow: 1; width: 100%; min-width: 100%; max-width: 100%; height: 30%; min-height: 15%; max-height: 10%; background-color: rgb(0, 0, 0);"/>
                    <ui:VisualElement name="Decor" style="flex-grow: 1; width: 100%; min-width: 100%; max-width: 100%; height: 30%; min-height: 10%; max-height: 10%; background-color: rgb(97, 91, 50);"/>
                    <ui:VisualElement name="Item" style="flex-grow: 1; width: 100%; min-width: 100%; max-width: 100%; height: 30%; min-height: 15%; max-height: 10%; background-color: rgb(0, 0, 0);"/>
